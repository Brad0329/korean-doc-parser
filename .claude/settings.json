      "Bash(rm -fr *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout --*)",
      "Bash(git restore --staged*)",
      "Bash(git commit --amend*)",
      "Bash(git rebase*)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)"
    ]
  }
